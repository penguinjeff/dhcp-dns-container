      "PodmanManager": {
        "ansible_host": "192.168.0.200",
        "ansible_user": "root",
        "parent_interface": "br0",
        "vlan_ip": "172.222.0.200"
      },

      "garage": {
        "ansible_host": "192.168.0.151",
        "ansible_user": "root",
        "parent_interface": "eth0",
        "vlan_ip": "172.222.0.151"
      }
    },

    "vars": {
      "vlan_id": 2222
    }
