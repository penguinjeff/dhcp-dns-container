{
  "name": "Deploy home_web project directory",
  "hosts": "all",
  "become": true,
  "tasks": [
    {
      "name": "Ensure docker-compose-configs directory exists",
      "file": {
        "path": "{{ ansible_env.HOME }}/docker-compose-configs",
        "state": "directory",
        "mode": "0755"
      }
    },
    {
      "name": "Check if home_web directory exists",
      "stat": {
        "path": "{{ ansible_env.HOME }}/docker-compose-configs/home_web"
      },
      "register": "home_web_dir"
    },
    {
      "name": "Create home_web directory ONLY if missing",
      "file": {
        "path": "{{ ansible_env.HOME }}/docker-compose-configs/home_web",
        "state": "directory",
        "mode": "0755"
      },
      "when": "home_web_dir.stat.exists == false"
    },
    {
      "name": "Ensure home_web is ignored by git",
      "lineinfile": {
        "path": "{{ ansible_env.HOME }}/.gitignore",
        "line": "docker-compose-configs/home_web/",
        "create": true
      }
    },
    {
      "name": "Create index.php ONLY if home_web directory was just created",
      "copy": {
        "dest": "{{ ansible_env.HOME }}/docker-compose-configs/home_web/index.php",
        "mode": "0644",
        "content": "<?php\n$server = gethostname();\n$client = $_SERVER['REMOTE_ADDR'];\necho \"<h1>Server: $server</h1>\";\necho \"<h2>Client IP: $client</h2>\";\n?>"
      },
      "when": "home_web_dir.stat.exists == false"
    },
    {
      "name": "Deploy Containerfile for home_web",
      "copy": {
        "dest": "{{ ansible_env.HOME }}/docker-compose-configs/home_web/Containerfile",
        "mode": "0644",
        "content": "FROM fedora:latest\nRUN dnf install -y php php-cli php-fpm httpd && dnf clean all\nCOPY . /var/www/html/\nCMD [\"/usr/sbin/httpd\", \"-D\", \"FOREGROUND\"]"
      }
    },
    {
      "name": "Deploy docker-compose.yml for home_web",
      "copy": {
        "dest": "{{ ansible_env.HOME }}/docker-compose-configs/home_web/docker-compose.yml",
        "mode": "0644",
        "content": "version: '3.9'\n\nservices:\n  home_web:\n    build:\n      context: .\n      dockerfile: Containerfile\n    container_name: home_web\n    network_mode: host\n    restart: always\n    volumes:\n      - .:/var/www/html:ro\n"
      }
    }
  ]
}
