[
  {
    "name": "Configure VLANs on hosts",
    "hosts": "vlan_hosts",
    "become": true,
    "tasks": [
      {
        "name": "DEBUG — show hostvars for VLAN",
        "debug": {
          "msg": {
            "host": "{{ inventory_hostname }}",
            "vlan_ip": "{{ vlan_ip | default('MISSING') }}",
            "parent_interface": "{{ parent_interface | default('MISSING') }}",
            "vlan_id": "{{ vlan_id }}"
          }
        }
      },
      {
        "name": "Create persistent VLAN interface",
        "community.general.nmcli": {
          "type": "vlan",
          "conn_name": "vlan{{ vlan_id }}",
          "ifname": "{{ parent_interface }}.{{ vlan_id }}",
          "vlandev": "{{ parent_interface }}",
          "vlanid": "{{ vlan_id }}",
          "ip4": "{{ vlan_ip }}/16",
          "method4": "manual",
          "autoconnect": true,
          "state": "present"
        },
        "when": "parent_interface is defined and vlan_ip is defined"
      }
    ]
  }
]
