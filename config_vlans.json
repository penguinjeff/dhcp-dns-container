[
  {
    "name": "Configure VLANs on hosts",
    "hosts": "vlan_hosts",
    "become": true,
    "tasks": [
      {
        "name": "DEBUG — show hostvars for VLAN",
        "debug": {
          "msg": {
            "host": "{{ inventory_hostname }}",
            "vlan_ip": "{{ hostvars[inventory_hostname].vlan_ip | default('MISSING') }}",
            "parent_interface": "{{ hostvars[inventory_hostname].parent_interface | default('MISSING') }}"
          }
        }
      },
      {
        "name": "Create VLAN interface",
        "community.general.nmcli": {
          "type": "vlan",
          "conn_name": "vlan{{ vlan_id }}",
          "ifname": "vlan{{ vlan_id }}",
          "vlandev": "{{ hostvars[inventory_hostname].parent_interface }}",
          "vlanid": "{{ vlan_id }}",
          "state": "present",
          "ip4": "{{ hostvars[inventory_hostname].vlan_ip }}/24",
          "method4": "manual"
        }
      }
    ]
  }
]
