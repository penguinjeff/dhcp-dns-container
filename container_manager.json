{
  "name": "Configure container roles, install update script, and schedule updates",
  "hosts": "all",
  "become": true,
  "tasks": [
    {
      "name": "Ensure containers-enabled directories exist",
      "loop": [
        "{{ ansible_env.HOME }}/containers-enabled",
        "{{ ansible_env.HOME }}/containers-enabled/normal",
        "{{ ansible_env.HOME }}/containers-enabled/ha"
      ],
      "file": {
        "path": "{{ item }}",
        "state": "directory",
        "mode": "0755"
      }
    },

    {
      "name": "Clear old normal symlinks",
      "with_fileglob": [
        "{{ ansible_env.HOME }}/containers-enabled/normal/*"
      ],
      "file": {
        "path": "{{ item }}",
        "state": "absent"
      }
    },

    {
      "name": "Clear old ha symlinks",
      "with_fileglob": [
        "{{ ansible_env.HOME }}/containers-enabled/ha/*"
      ],
      "file": {
        "path": "{{ item }}",
        "state": "absent"
      }
    },

    {
      "name": "Create normal container symlinks (only if container exists)",
      "loop": "{{ hostvars[inventory_hostname].normal_containers | default([]) }}",
      "when": "lookup('ansible.builtin.fileglob', ansible_env.HOME + '/docker-compose-configs/' + item, errors='ignore')",
      "file": {
        "src": "{{ ansible_env.HOME }}/docker-compose-configs/{{ item }}",
        "dest": "{{ ansible_env.HOME }}/containers-enabled/normal/{{ item }}",
        "state": "link"
      }
    },

    {
      "name": "Create HA container symlinks (only if container exists)",
      "loop": "{{ hostvars[inventory_hostname].ha_containers | default([]) }}",
      "when": "lookup('ansible.builtin.fileglob', ansible_env.HOME + '/docker-compose-configs/' + item, errors='ignore')",
      "file": {
        "src": "{{ ansible_env.HOME }}/docker-compose-configs/{{ item }}",
        "dest": "{{ ansible_env.HOME }}/containers-enabled/ha/{{ item }}",
        "state": "link"
      }
    },

    {
      "name": "Install update_podman_containers.sh",
      "copy": {
        "src": "files/update_podman_containers.sh",
        "dest": "/usr/local/bin/update_podman_containers.sh",
        "mode": "0755"
      }
    },

    {
      "name": "Install cron job for nightly container updates",
      "cron": {
        "name": "Nightly Podman container update",
        "user": "root",
        "job": "/usr/local/bin/update_podman_containers.sh",
        "minute": "{{ hostvars[inventory_hostname].update_time.split(':')[1] }}",
        "hour": "{{ hostvars[inventory_hostname].update_time.split(':')[0] }}",
        "state": "present"
      }
    },

    {
      "name": "Install cron job for nightly Podman cleanup",
      "cron": {
        "name": "Nightly Podman cleanup",
        "user": "root",
        "job": "/usr/bin/podman system prune -f",
        "minute": "{{ hostvars[inventory_hostname].cleanup_time.split(':')[1] }}",
        "hour": "{{ hostvars[inventory_hostname].cleanup_time.split(':')[0] }}",
        "state": "present"
      }
    }
  ]
}
