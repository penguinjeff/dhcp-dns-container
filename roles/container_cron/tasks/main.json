[
  {
    "name": "Install cron job for nightly container updates",
    "cron": {
      "name": "Nightly Podman container update",
      "user": "root",
      "job": "/usr/local/bin/update_podman_containers.sh",
      "minute": "{{ hostvars[inventory_hostname].update_time.split(':')[1] }}",
      "hour": "{{ hostvars[inventory_hostname].update_time.split(':')[0] }}",
      "state": "present"
    }
  },
  {
    "name": "Install cron job for nightly Podman cleanup",
    "cron": {
      "name": "Nightly Podman cleanup",
      "user": "root",
      "job": "/usr/bin/podman system prune -f",
      "minute": "{{ hostvars[inventory_hostname].cleanup_time.split(':')[1] }}",
      "hour": "{{ hostvars[inventory_hostname].cleanup_time.split(':')[0] }}",
      "state": "present"
    }
  }
]
